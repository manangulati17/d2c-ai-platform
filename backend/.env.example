# Environment - either "dev" or "prod"
ENV=dev

# PostgreSQL database connection string (format: postgresql://user:password@host:port/dbname)
DATABASE_URL=

# OpenRouter API key for LLM access in development
OPENROUTER_API_KEY=

# OpenRouter base URL
OPENROUTER_BASE_URL=

# Azure OpenAI API key for production LLM access
AZURE_OPENAI_API_KEY=

# Azure OpenAI endpoint URL
AZURE_OPENAI_ENDPOINT=

# Azure OpenAI deployment name
AZURE_OPENAI_DEPLOYMENT=

# Shopify API key for accessing store data
SHOPIFY_API_KEY=

# Shopify store URL (e.g., yourstore.myshopify.com)
SHOPIFY_STORE_URL=

# Razorpay key ID for payment data access
RAZORPAY_KEY_ID=

# Razorpay key secret for authentication
RAZORPAY_KEY_SECRET=

# Meta (Facebook) access token for Ads API
META_ACCESS_TOKEN=

# Meta Ads account ID to fetch campaign data
META_AD_ACCOUNT_ID=

# Redis URL for Celery task queue
CELERY_BROKER_URL=redis://localhost:6379/0
